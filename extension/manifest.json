{
  "manifest_version": 3,
  "name": "Trading Journal Sync",
  "version": "1.2",
  "description": "Sync TradingView charts directly to your Journal",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "clipboardRead",
    "storage",
    "tabs",
    "notifications",
    "scripting"
  ],
  "host_permissions": [
    "https://www.tradingview.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://localhost:8080/*",
    "https://*.pages.dev/*",
    "https://trading-journal-3di.pages.dev/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.tradingview.com/chart/*"],
      "js": ["content.js"]
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://localhost:8080/*",
        "https://*.pages.dev/*"
      ],
      "js": ["journal-content.js"],
      "run_at": "document_start"
    }
  ]
}
